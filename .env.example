# Spriterrific — variables d'environnement (copier vers .env et remplir)
# Documentation : docs/cles-api.md

# === Obligatoire pour la génération image/vidéo via fal.ai ===
# Obtenir une clé : https://fal.ai/dashboard/keys
FAL_KEY=

# Alias accepté (une seule des deux suffit)
FAL_API_KEY=

# === Optionnel ===
# Mentionné dans la doc upstream ; non utilisé par le code actuel du fork.
# REMOVE_BG_API_KEY=
